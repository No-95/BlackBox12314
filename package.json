{
  "name": "agent-box-v1",
  "version": "1.0.0",
  "description": "Portable, zero-budget AI Company in a box for B2B workflows.",
  "main": "index.js",
  "scripts": {
    "dev": "npx convex dev",
    "deploy": "npx convex deploy",
    "codegen": "npx convex codegen",
    "lite:setup": "npm install --prefix scripts/playwright && npx playwright install chromium",
    "lite:n8n": "npx n8n start --port 5678",
    "lite:poster": "npm --prefix scripts/playwright start",
    "outreach:import": "node scripts/outreach/import-google-sheet.js",
    "outreach:run": "node scripts/outreach/run-hourly-batch.js",
    "outreach:schedule": "powershell -ExecutionPolicy Bypass -File scripts/outreach/register-hourly-task.ps1",
    "outreach:webhook": "node scripts/outreach/receive-resend-events.js",
    "sales:dashboard": "node apps/sales-dashboard/server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "convex": "^1.22.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "googleapis": "^148.0.0",
    "resend": "^4.1.2"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
