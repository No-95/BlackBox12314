{
  "name": "blackbox-desktop",
  "version": "1.0.0",
  "description": "BlackBox offline desktop client — UI on Windows, backend on Ubuntu",
  "main": "main.js",
  "author": "HDPHoldings",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.hdpholdings.blackbox",
    "productName": "BlackBox",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "icon": "build/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "setup.html",
      "defaults.json",
      "icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../sales-dashboard/public",
        "to": "ui",
        "filter": ["**/*"]
      },
      {
        "from": "tunnel.bat",
        "to": "tunnel.bat",
        "filter": ["tunnel.bat"]
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "BlackBox-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "BlackBox-${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BlackBox"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
