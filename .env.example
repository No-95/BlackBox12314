# -----------------------------
# Core platform
# -----------------------------
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me
POSTGRES_DB=n8n
POSTGRES_PORT=5432

N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh

N8N_ENCRYPTION_KEY=replace_with_32_plus_chars
N8N_USER_MANAGEMENT_JWT_SECRET=replace_with_32_plus_chars
N8N_SECURE_COOKIE=false

# -----------------------------
# 24/7 hybrid AI strategy
# AI_MODE: local | cloud
# -----------------------------
AI_MODE=cloud

# Local LLM endpoint (inside docker)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434

# Local PC fallback endpoints (from cloud container to your home PC)
LOCAL_PC_OLLAMA_URL=http://host.docker.internal:11434
COMFYUI_BASE_URL=http://host.docker.internal:8188

# Free cloud API keys (fill later)
GROQ_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Convex (optional memory/backend)
CONVEX_URL=
CONVEX_DEPLOY_KEY=

# -----------------------------
# Browser automation
# -----------------------------
BROWSERLESS_PORT=3000
BROWSERLESS_TOKEN=replace_with_random_token
POSTER_PORT=8080
PLAYWRIGHT_POSTER_URL=http://playwright-poster:8080/post

TARGET_BASE_URL=https://www.instagram.com
TARGET_USERNAME=
TARGET_PASSWORD=
