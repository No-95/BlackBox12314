# -----------------------------------------------
# Convex
# -----------------------------------------------
CONVEX_URL=https://glad-jaguar-211.convex.cloud
CONVEX_SITE_URL=https://glad-jaguar-211.convex.site
CONVEX_DEPLOY_KEY=

# -----------------------------------------------
# Sales outreach settings
# -----------------------------------------------
OUTREACH_TENANT_ID=default
OUTREACH_BATCH_SIZE=2
OUTREACH_MAX_ATTEMPTS=3

# -----------------------------------------------
# Google Sheet intake
# -----------------------------------------------
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE='Sheet1'!A1:Z

# -----------------------------------------------
# AI drafting (ChatAnywhere — OpenAI-compatible)
# https://api.chatanywhere.tech
# -----------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.chatanywhere.tech/v1
AI_DRAFT_MODEL=gpt-4o-mini
LAWYER_MODEL=gpt-4o-mini

# AI scene generation (Content Creator — not used for email drafting)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------
# Content Creator integrations
# Add these to unlock higher-quality image and video generation
OPENAI_API_KEY=
GOOGLE_IMAGEN_API_KEY=
RECRAFT_API_KEY=
FLUX_API_KEY=
KLING_API_KEY=
RUNWAY_API_KEY=
VEO_API_KEY=
ELEVENLABS_API_KEY=

# -----------------------------------------------
# Pixelle video engine
# Start Pixelle API with: uv run uvicorn api.app:app --host 0.0.0.0 --port 8000
PIXELLE_BASE_URL=http://127.0.0.1:8000
PIXELLE_RENDER_MODE=sync
PIXELLE_RENDER_TIMEOUT_MS=900000
PIXELLE_POLL_INTERVAL_MS=5000
PIXELLE_DEFAULT_TEMPLATE=1080x1920/image_default.html
PIXELLE_DEFAULT_TTS_WORKFLOW=
PIXELLE_DEFAULT_MEDIA_WORKFLOW=selfhost/image_flux.json
PIXELLE_PROMPT_PREFIX=Modern product-focused social ad, polished lighting, cinematic composition, high detail
PIXELLE_BGM_PATH=
PIXELLE_BGM_VOLUME=0.3
PIXELLE_API_KEY=
STRICT_REAL_PROVIDERS=true

# -----------------------------------------------
# Resend email sender
# -----------------------------------------------
RESEND_API_KEY=
# Fill this after verifying your sender domain in Resend
RESEND_FROM_EMAIL=business@hdpholdings.com.vn
RESEND_FROM_NAME=HDPHoldings
CALENDLY_LINK=https://www.hdptradehub.com/global-furniture-business-roadshow

# -----------------------------------------------
# Ports / remote access (Ubuntu server B)
# -----------------------------------------------
SALES_DASHBOARD_HOST=0.0.0.0
SALES_DASHBOARD_PORT=5177
RESEND_WEBHOOK_PORT=8090
BLACKBOX_API_TOKEN=
BLACKBOX_CORS_ORIGINS=*

# -----------------------------------------------
# Visionist (MiroFish via sales dashboard)
# Clone MiroFish: npm run mirofish:setup → cd apps/mirofish && npm run setup:all
# -----------------------------------------------
MIROFISH_BASE_URL=http://127.0.0.1:5001
MIROFISH_FRONTEND_PATH=D:/MiroFish/MiroFish/frontend
VISIONIST_MAX_ROUNDS=24
