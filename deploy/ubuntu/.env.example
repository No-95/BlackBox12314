# BlackBox Ubuntu Server (Computer B)
# Copy this file to .env and fill secrets before starting.

# Public API token for BlackBox.exe clients
BLACKBOX_API_TOKEN=change-me-to-a-long-random-string
BLACKBOX_CORS_ORIGINS=*

# Bind dashboard for reverse proxy
SALES_DASHBOARD_HOST=0.0.0.0
SALES_DASHBOARD_PORT=5177

# Domain used by Caddy for HTTPS
BLACKBOX_DOMAIN=blackbox.example.com

# Convex
CONVEX_URL=
CONVEX_DEPLOY_KEY=
OUTREACH_TENANT_ID=default

# ChatAnywhere (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.chatanywhere.tech/v1
AI_DRAFT_MODEL=gpt-4o-mini
LAWYER_MODEL=gpt-4o-mini

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=HDPHoldings
CALENDLY_LINK=

# Google Sheets (path inside container or host-mounted JSON)
GOOGLE_SERVICE_ACCOUNT_JSON=/data/secrets/google-service-account.json
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE='Sheet1'!A1:Z

# Local AI / media services on B
MIROFISH_BASE_URL=http://mirofish:5001
PIXELLE_BASE_URL=http://host.docker.internal:8000
COMFYUI_BASE_URL=http://host.docker.internal:8188
STRICT_REAL_PROVIDERS=true
